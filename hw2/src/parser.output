文法

    0 $accept: program $end

    1 program: ID SEMI global_decl_block function_block compound_statement END

    2 global_decl_block: ε
    3                  | global_decl_block declaration

    4 function_block: ε
    5               | function_block function

    6 function: function_header SEMI
    7         | function_header compound_statement END

    8 function_header: ID LPAREN opt_formal_args RPAREN opt_return

    9 opt_formal_args: ε
   10                | formal_arg_list

   11 formal_arg_list: formal_argument
   12                | formal_arg_list SEMI formal_argument

   13 formal_argument: identifier_list COLON type

   14 opt_return: ε
   15           | COLON scalar_type

   16 statement: assignment
   17          | print_statement
   18          | read_statement
   19          | return_statement
   20          | function_call SEMI
   21          | conditional_statement
   22          | while_statement
   23          | for_statement
   24          | compound_statement

   25 print_statement: PRINT expression SEMI

   26 read_statement: READ variable_reference SEMI

   27 return_statement: RETURN expression SEMI

   28 conditional_statement: IF expression THEN compound_statement ELSE compound_statement END IF
   29                      | IF expression THEN compound_statement END IF

   30 while_statement: WHILE expression DO compound_statement END DO

   31 for_statement: FOR ID ASSIGN INTEGER_LITERAL TO INTEGER_LITERAL DO compound_statement END DO

   32 compound_statement: BEGIN_T declaration_block statement_block END

   33 declaration_block: ε
   34                  | declaration_block declaration

   35 declaration: VAR identifier_list COLON type SEMI
   36            | VAR identifier_list COLON const_value SEMI

   37 identifier_list: ID
   38                | identifier_list COMMA ID

   39 type: scalar_type
   40     | array_type

   41 scalar_type: INTEGER_T
   42            | REAL_T
   43            | STRING_T
   44            | BOOLEAN_T

   45 array_type: ARRAY INTEGER_LITERAL OF type

   46 const_value: INTEGER_LITERAL
   47            | REAL_LITERAL
   48            | STRING_LITERAL
   49            | BOOLEAN_LITERAL

   50 statement_block: ε
   51                | statement_block statement

   52 assignment: variable_reference ASSIGN expression SEMI

   53 variable_reference: ID
   54                   | variable_reference LBRACK expression RBRACK

   55 function_call: ID LPAREN argument_list RPAREN

   56 argument_list: ε
   57              | expr_list

   58 expr_list: expression
   59          | expr_list COMMA expression

   60 expression: primary
   61           | expression PLUS expression
   62           | expression MINUS expression
   63           | expression STAR expression
   64           | expression SLASH expression
   65           | expression MOD_T expression
   66           | expression LT expression
   67           | expression LE expression
   68           | expression NE expression
   69           | expression GE expression
   70           | expression GT expression
   71           | expression EQ expression
   72           | expression AND expression
   73           | expression OR expression
   74           | MINUS expression
   75           | NOT_T expression
   76           | LPAREN expression RPAREN

   77 primary: literal_constant
   78        | variable_reference
   79        | function_call

   80 literal_constant: INTEGER_LITERAL
   81                 | REAL_LITERAL
   82                 | STRING_LITERAL
   83                 | BOOLEAN_LITERAL


